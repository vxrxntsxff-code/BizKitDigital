{
    "version": 2,
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/$1" },
        { "src": "/\\.uploads/(.*)", "dest": "/.uploads/$1" },
        { "src": "/(offer|requisites|success|cases|blog|contract)\\.html", "dest": "/$1.html" },
        { "src": "/common\\.css", "dest": "/common.css" },
        { "src": "/chat\\.js", "dest": "/chat.js" },
        { "src": "/sitemap\\.xml", "dest": "/sitemap.xml" },
        { "src": "/robots\\.txt", "dest": "/robots.txt" }
    ]
}
